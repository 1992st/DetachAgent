{
  "app": "detaches_agent",
  "provider": "detaches_agent",
  "channel": "detaches_agent",
  "sessionMode": "main",
  "sessionKey": "agent:audio-process:main",
  "agentId": "audio-process",
  "detaches": {
    "app": "detaches_agent",
    "version": 1,
    "sessionMode": "main",
    "sessionKey": "agent:audio-process:main",
    "agentId": "audio-process",
    "userDevice": {
      "deviceId": "detaches-test-device",
      "deviceIdShort": "detaches",
      "displayName": "detaches test machine",
      "sessionNamespace": "detaches:detaches"
    },
    "localMachine": {
      "os": "win32",
      "nodePlatform": "win32",
      "arch": "x64",
      "shell": "powershell.exe",
      "pathStyle": "windows",
      "pathSeparator": "\\",
      "commandDialect": "powershell",
      "appDataDir": "C:\\Users\\alice\\.detach_agent"
    },
    "broker": {
      "gatewayEventEndpoint": "http://127.0.0.1:38888/api/tools/events/gateway",
      "interactionEventEndpoint": "http://127.0.0.1:38888/api/interactions/events/gateway",
      "eventSource": "gateway-event",
      "idempotencyField": "sourceEventId",
      "submitToken": "client-context-submit-token",
      "submitTokenHeader": "Authorization",
      "requestFormats": ["broker-event", "fence"]
    },
    "localControl": {
      "baseUrl": "http://127.0.0.1:38888",
      "toolEventEndpoint": "http://127.0.0.1:38888/api/tools/events/gateway",
      "interactionEventEndpoint": "http://127.0.0.1:38888/api/interactions/events/gateway",
      "fixedPort": 38888,
      "submitTokenHeader": "Authorization",
      "addressSource": "remote-reachable-context",
      "reverseBridge": {
        "ok": true,
        "message": "SSH reverse broker bridge is ready.",
        "reverseBrokerUrl": "http://127.0.0.1:38888",
        "pid": 1234
      },
      "note": "Use this context-provided URL from the Host/Main Agent machine."
    },
    "contextExport": {
      "createEndpoint": "http://127.0.0.1:38888/api/context/exports",
      "consumeEndpointPattern": "http://127.0.0.1:38888/api/context/exports/{token}",
      "createdBy": "detaches-ui-loopback",
      "consumedBy": "remote-agent-host",
      "oneTime": true,
      "ttlSeconds": 300,
      "adapterCommand": "context-fetch",
      "doctorCommand": "doctor",
      "note": "Ask the user to send a fresh detaches_agent message with current connection settings."
    },
    "capabilities": [
      {
        "name": "terminal",
        "requestFence": "detaches-terminal",
        "supportedTargets": ["local-user-machine"],
        "unavailableTargets": ["remote-agent-host", "gateway-managed"],
        "approvalRequired": true,
        "executionHost": "user-local-machine"
      }
    ],
    "invariants": [
      "Tools are never executed by assistant text alone."
    ]
  }
}
