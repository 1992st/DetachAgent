{
  "schemaVersion": 1,
  "id": "detaches_agent.openclaw.skill",
  "name": "detaches_agent Session Bridge",
  "description": "Agent-side skill metadata for OpenClaw sessions mediated by detaches_agent.",
  "adapterId": "detaches_agent.openclaw.adapter",
  "entrypoints": {
    "skill": "SKILL.md",
    "instructions": "AGENT.md",
    "adapterManifest": "adapter.manifest.json",
    "cli": "bin/detaches-agent-adapter.mjs"
  },
  "commands": {
    "doctorUrl": "node ~/.detach_agent/bin/detaches-agent-adapter.mjs doctor --url <one-time-context-export-url> --output-context /tmp/detaches-client-context.json",
    "doctorContext": "node ~/.detach_agent/bin/detaches-agent-adapter.mjs doctor --context /tmp/detaches-client-context.json",
    "fetchContext": "node ~/.detach_agent/bin/detaches-agent-adapter.mjs context-fetch <one-time-context-export-url> --output /tmp/detaches-client-context.json",
    "inspectContext": "node ~/.detach_agent/bin/detaches-agent-adapter.mjs inspect-context /tmp/detaches-client-context.json",
    "probeBroker": "node ~/.detach_agent/bin/detaches-agent-adapter.mjs broker-probe <detaches-agent-base-url>",
    "terminalRequest": "node ~/.detach_agent/bin/detaches-agent-adapter.mjs terminal-request --context /tmp/detaches-client-context.json --target local-user-machine --format broker-event --submit",
    "fileTransferRequest": "node ~/.detach_agent/bin/detaches-agent-adapter.mjs file-transfer-request --context /tmp/detaches-client-context.json --target local-user-machine --format broker-event --submit",
    "mainAgentSaveFileRequest": "node ~/.detach_agent/bin/detaches-agent-adapter.mjs main-agent-save-file-request --context /tmp/detaches-client-context.json --format broker-event --submit"
  },
  "context": {
    "accepts": [
      "clientContext.detaches",
      "clientContext",
      "one-time context export URL"
    ],
    "sensitiveFields": [
      "broker.submitToken"
    ]
  },
  "safety": {
    "requiresUserApproval": true,
    "executesToolsDirectly": false,
    "approvalBroker": "detaches_agent local UI",
    "forbiddenFallbacks": [
      "remote-agent-host -> local-user-machine",
      "gateway-managed -> local-user-machine",
      "main-agent-machine -> local-user-machine"
    ]
  }
}
