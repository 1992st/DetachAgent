{
  "name": "@detaches/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.json",
    "dev": "DETACHES_DESKTOP_DEV=1 electron .",
    "stage:runtime": "node scripts/stage-runtime.mjs",
    "package:win": "pnpm --dir ../.. build && pnpm build && pnpm stage:runtime && electron-builder --win nsis --x64"
  },
  "dependencies": {
    "electron-is-dev": "^3.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "typescript": "^5.8.3"
  },
  "build": {
    "extends": "./electron-builder.yml"
  }
}
